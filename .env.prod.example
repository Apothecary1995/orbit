# ══════════════════════════════════════════════════════
#  Orbit — Production Environment Variables
#  Kopyala: cp .env.prod.example .env.prod
#  Sonra tüm değerleri doldur, commit etme!
# ══════════════════════════════════════════════════════

# ── PostgreSQL ─────────────────────────────────────────
DB_USER=orbit
DB_PASSWORD=GUCLU_SIFRE_KOY
DB_NAME=orbit_db

# ── Redis ──────────────────────────────────────────────
REDIS_PASSWORD=BASKA_GUCLU_SIFRE

# ── JWT — mutlaka güçlü bir secret üret ────────────────
# Üretmek için: openssl rand -hex 64
JWT_SECRET=

# ── RabbitMQ ───────────────────────────────────────────
RABBITMQ_USER=orbit
RABBITMQ_PASS=RABBITMQ_SIFRE

# ── MinIO ──────────────────────────────────────────────
MINIO_ROOT_USER=orbit
MINIO_ROOT_PASSWORD=MINIO_SIFRE_EN_AZ_8_KARAKTER
MINIO_PUBLIC_URL=https://orbit.yourdomain.com/files

# ── CORS ───────────────────────────────────────────────
ALLOWED_ORIGIN=https://orbit.yourdomain.com

# ── Grafana ────────────────────────────────────────────
GRAFANA_PASSWORD=GRAFANA_ADMIN_SIFRE

# ── VAPID (web push) ───────────────────────────────────
# Üretmek için: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@yourdomain.com
