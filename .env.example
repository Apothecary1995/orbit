# ── PostgreSQL ────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=cengsta
DB_PASSWORD=secret
DB_NAME=cengsta_paradise

# ── Redis ─────────────────────────────────────────────────
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=secret

# ── JWT — ÜRETİMDE MUTLAKA DEĞİŞTİR ─────────────────────
JWT_SECRET=change-me-in-production

# ── gRPC Portları ─────────────────────────────────────────
AUTH_GRPC_PORT=:50051
CHAT_GRPC_PORT=:50052

# ── API Gateway ───────────────────────────────────────────
GATEWAY_HTTP_PORT=:8080
AUTH_SVC_ADDR=localhost:50051
CHAT_SVC_ADDR=localhost:50052

# ── MinIO (S3 uyumlu dosya depolama) ─────────────────────
MINIO_PUBLIC_URL=http://localhost:9000/orbit-files

# ── CORS ─────────────────────────────────────────────────
# Geliştirme: http://localhost:5173
# Uretim: https://yourdomain.com
ALLOWED_ORIGIN=http://localhost:5173

# ── GO ortami ────────────────────────────────────────────
# production | development
GO_ENV=development

# ── VAPID (Web Push Bildirimleri) ─────────────────────────
# Uretmek icin: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
